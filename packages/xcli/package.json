{
  "name": "xcli",
  "version": "1.0.0",
  "type": "module",
  "bin": {
    "xcli": "dist/bin/xcli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@xcli/core": "workspace:*",
    "@xcli/tips": "workspace:*",
    "@xcli/daemon": "workspace:*",
    "@xcli/session": "workspace:*",
    "@xcli/browser": "workspace:*",
    "@dyyz1993/xpage": "workspace:*",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
