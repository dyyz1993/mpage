{
  "name": "create-xcli",
  "version": "0.2.3",
  "description": "Scaffold a new xcli project",
  "type": "module",
  "bin": {
    "create-xcli": "dist/create-xcli.js"
  },
  "main": "dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "xcli",
    "create",
    "scaffold",
    "cli",
    "template"
  ],
  "author": "dyyz1993",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dyyz1993/mpage.git",
    "directory": "packages/create-xcli"
  },
  "dependencies": {
    "@dyyz1993/xcli-core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
