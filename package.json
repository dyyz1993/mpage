{
  "name": "@dyyz1993/xpage",
  "version": "1.0.2",
  "description": "Playwright browser automation CLI with CDP support",
  "private": true,
  "type": "module",
  "bin": {
    "mpage": "dist/bin/mpage.js"
  },
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "xpage": "npx tsx bin/mpage.ts",
    "build:packages": "pnpm -r --filter './packages/*' --sort run build",
    "build": "pnpm run build:packages && tsup",
    "dev": "npx tsx bin/mpage.ts",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:packages": "pnpm -r --filter './packages/*' --stream run lint",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.ts\" \"bin/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"bin/**/*.ts\" \"tests/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "typecheck:packages": "pnpm -r --filter './packages/*' --stream run typecheck",
    "test": "tsx --test tests/**/*.test.ts",
    "test:plugins": "tsx tests/e2e/plugin-test-runner.ts",
    "prepublishOnly": "npm run build",
    "prepare": "husky",
    "validate": "npm run typecheck && npm run lint && npm run build && npm test",
    "validate:mpage": "npm run typecheck && npm run lint && npm run build",
    "validate:xcli": "cd xcli && npm run typecheck && npm run lint && npm test"
  },
  "lint-staged": {
    "*.ts": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "dependencies": {
    "playwright": "^1.59.1",
    "playwright-core": "^1.58.2",
    "yaml": "^2.8.2",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "jsdom": "^29.0.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.0"
  },
  "keywords": [
    "playwright",
    "browser",
    "automation",
    "cdp",
    "cli"
  ],
  "author": "dyyz1993",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": ""
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
