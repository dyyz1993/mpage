{
  "name": "@dyyz1993/xpage",
  "version": "1.0.5",
  "description": "Browser automation engine library based on Playwright",
  "private": false,
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build:root": "tsup",
    "build:packages": "pnpm -r --filter './packages/*' --sort --workspace-concurrency=1 run build",
    "build": "pnpm run build:root && pnpm run build:packages",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:packages": "pnpm -r --filter './packages/*' --stream run lint",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "typecheck:packages": "pnpm -r --filter './packages/*' --stream run typecheck",
    "test": "vitest run",
    "test:core": "cd packages/core && vitest run",
    "test:all": "vitest run && pnpm run test:core",
    "prepublishOnly": "npm run build",
    "prepare": "husky",
    "validate": "npm run typecheck && npm run lint && npm run build && npm run test",
    "docs:dev": "cd website && npm run docs:dev",
    "docs:build": "cd website && npm run docs:build",
    "docs:preview": "cd website && npm run docs:preview"
  },
  "lint-staged": {
    "*.ts": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "dependencies": {
    "playwright": "^1.59.1",
    "playwright-core": "^1.58.2",
    "ws": "^8.20.0",
    "yaml": "^2.8.2",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@dyyz1993/xcli-core": "workspace:*",
    "@types/node": "^20.0.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "jsdom": "^29.0.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.0"
  },
  "keywords": [
    "playwright",
    "browser",
    "automation",
    "cdp",
    "recording",
    "playback",
    "engine"
  ],
  "author": "dyyz1993",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": ""
  },
  "pnpm": {
    "overrides": {
      "playwright": "^1.59.1",
      "playwright-core": "^1.58.2"
    }
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
