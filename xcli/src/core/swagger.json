{
  "openapi": "3.0.0",
  "info": {
    "title": "XCLI Daemon API",
    "version": "1.0.0",
    "description": "XCLI Daemon HTTP RPC API"
  },
  "servers": [
    {
      "url": "http://localhost:8054"
    }
  ],
  "paths": {
    "/rpc": {
      "post": {
        "summary": "Execute RPC command",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "method": {
                    "type": "string",
                    "description": "Command in format 'namespace.action'"
                  },
                  "params": {
                    "type": "object",
                    "description": "Command parameters"
                  }
                },
                "required": ["method"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response"
          }
        }
      }
    },
    "/api/sessions": {
      "get": {
        "summary": "List all sessions",
        "responses": {
          "200": {
            "description": "List of active sessions"
          }
        }
      }
    }
  }
}