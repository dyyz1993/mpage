{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "paths": {
      "xcli": ["./src/index.ts"]
    }
  },
  "include": [".xcli/plugins/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
