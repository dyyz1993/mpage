{
  "name": "xcli",
  "version": "1.0.0",
  "description": "Extensible CLI Framework",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": "./dist/src/index.js",
    "./protocol": "./dist/src/protocol/plugin-protocol.js",
    "./core": "./dist/src/core/plugin-loader.js"
  },
  "bin": {
    "xcli": "./dist/bin/xcli.js"
  },
  "scripts": {
    "build": "tsup",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "validate": "npm run typecheck && npm run lint && npm test"
  },
  "dependencies": {
    "@dyyz1993/xpage": "file:..",
    "jiti": "^2.4.0",
    "playwright": "^1.40.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/ui": "^4.1.5",
    "eslint": "^8.57.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.5"
  }
}
