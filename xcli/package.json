{
  "name": "xcli",
  "version": "1.0.0",
  "description": "Extensible CLI Framework",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./protocol": "./src/protocol/plugin-protocol.ts",
    "./core": "./src/core/plugin-loader.ts"
  },
  "bin": {
    "xcli": "./bin/xcli.ts"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@dyyz1993/xpage": "file:..",
    "jiti": "^2.4.0",
    "playwright": "^1.40.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/ui": "^4.1.5",
    "eslint": "^8.57.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.5"
  }
}
